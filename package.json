{
  "name": "mise-en-palace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "db:check": "pnpm --filter @krn/db db:check",
    "db:generate": "pnpm --filter @krn/db db:generate",
    "db:ready": "pnpm --filter @krn/cli krn db readiness",
    "db:smoke": "pnpm --filter @krn/cli krn db smoke",
    "db:smoke:harness-evidence": "pnpm --filter @krn/cli krn db smoke harness-evidence",
    "db:smoke:harness-plan": "pnpm --filter @krn/cli krn db smoke harness-plan",
    "db:smoke:memory-governance": "pnpm --filter @krn/cli krn db smoke memory-governance",
    "db:smoke:retrieval-substrate": "pnpm --filter @krn/cli krn db smoke retrieval-substrate",
    "db:smoke:source-graph": "pnpm --filter @krn/cli krn db smoke source-graph",
    "test": "pnpm -r --workspace-concurrency=1 --if-present test",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
