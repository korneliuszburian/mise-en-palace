{
  "name": "mise-en-palace",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "db:check": "pnpm --filter @krn/db db:check",
    "db:generate": "pnpm --filter @krn/db db:generate",
    "db:ready": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db readiness",
    "db:smoke": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke",
    "db:smoke:harness-evidence": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke harness-evidence",
    "db:smoke:harness-plan": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke harness-plan",
    "db:smoke:memory-governance": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke memory-governance",
    "db:smoke:retrieval-substrate": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke retrieval-substrate",
    "db:smoke:activation": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke activation",
    "db:smoke:codex-adapter": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke codex-adapter",
    "db:smoke:worker-jobs": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke worker-jobs",
    "db:smoke:init-connect": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke init-connect",
    "db:smoke:target-repo-harness": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke target-repo-harness",
    "db:smoke:source-graph": "KRN_DATABASE_URL=${KRN_DATABASE_URL:-postgres://krn:krn@localhost:54329/krn} pnpm --filter @krn/cli krn db smoke source-graph",
    "eval:brain-battle:smoke": "pnpm --filter @krn/harness test -- goldenKrnBehaviorGate && pnpm --filter @krn/cli test -- runRunShowCommand",
    "eval:promptfoo:smoke": "mkdir -p .local-lab/promptfoo && promptfoo eval -c tests/fixtures/promptfoo/krn-golden-smoke.yaml --output .local-lab/promptfoo/krn-golden-smoke-results.jsonl",
    "krn": "pnpm --filter @krn/cli krn",
    "alpha:verify": "pnpm typecheck && pnpm test && pnpm krn doctor",
    "test": "pnpm -r --workspace-concurrency=1 --if-present test",
    "typecheck": "pnpm -r --workspace-concurrency=1 typecheck"
  },
  "devDependencies": {
    "promptfoo": "^0.121.17",
    "typescript": "5.9.3"
  }
}
